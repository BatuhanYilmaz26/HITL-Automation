# Copy this file to .env and replace the placeholder values before starting the server.
# The values below are demo-oriented starter defaults.
# See README.md for recommended `demo`, `pilot`, and `enterprise-on-sheets` profiles.

# ── Google Sheets ────────────────────────────────────────────────────
# The long ID from the Sheet URL: https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
SPREADSHEET_ID=your-spreadsheet-id-here

# Name of the tab/sheet inside the spreadsheet (default: Sheet1)
SHEET_NAME=Sheet1

# ── Optional API-Key Fallback ────────────────────────────────────────
# Only used when REQUIRE_SERVICE_ACCOUNT=false and no service account file exists.
# Writes should use a service account in production.
GOOGLE_API_KEY=
SHEETS_API_KEY=

# ── Service Account ─────────────────────────────────────────────────
# Path to the Google Cloud service account JSON file.
# The spreadsheet must be shared with this service account as an Editor.
SERVICE_ACCOUNT_PATH=service_account.json
REQUIRE_SERVICE_ACCOUNT=true

# ── Webhook Security (optional) ──────────────────────────────────────
# Shared secret between Apps Script and FastAPI (leave blank to disable)
WEBHOOK_SECRET=

# ── Server ───────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
# Comma-separated list of allowed origins. Use * only for local testing.
CORS_ALLOW_ORIGINS=https://your-ada-domain.example
# Must remain false when CORS_ALLOW_ORIGINS=*.
ALLOW_CREDENTIALS=false

# ── Persistent Session Store ─────────────────────────────────────────
# Put this on durable storage outside the repo for long-running environments.
SESSION_DB_PATH=hitl_sessions.db
# How long completed or inactive sessions remain queryable.
SESSION_RETENTION_HOURS=168
# How often the cleanup worker removes expired sessions.
SESSION_CLEANUP_INTERVAL_SECONDS=1800
# Maximum allowed page size for GET /sessions.
SESSION_LIST_MAX_LIMIT=500

# ── Review Workers ───────────────────────────────────────────────────
# Number of worker loops that claim queued Sheets append jobs.
# Demo-oriented starter default.
REVIEW_WORKER_COUNT=4
# How long an idle worker sleeps before polling the queue again.
REVIEW_WORKER_IDLE_SLEEP_SECONDS=0.5
# How long an in-progress queue job can stay locked before being re-queued.
REVIEW_JOB_VISIBILITY_TIMEOUT_SECONDS=300

# ── Sheets API Tuning ────────────────────────────────────────────────
# Max concurrent Sheets API calls across all threads.
# This is a concurrency cap, not a full rate limiter.
SHEETS_API_CONCURRENT_LIMIT=5
# Seconds to keep a thread-local Sheets client alive before rebuilding it.
SHEETS_CLIENT_TTL_SECONDS=300

# ── Reconciliation ───────────────────────────────────────────────────
# Minimum seconds between Google Sheets reconciliations for the same pending session.
# Lower values improve fallback freshness but increase Sheets read pressure.
RECONCILIATION_COOLDOWN_SECONDS=15

# ── Debugging ────────────────────────────────────────────────────────
# Set to any value (e.g. DEBUG=1) to enable DEBUG-level logging
# DEBUG=1
