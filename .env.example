# ── Google Gemini API ────────────────────────────────────────────────
GOOGLE_API_KEY=your-gemini-api-key-here

# ── LLM Model ────────────────────────────────────────────────────────
# The Gemini model to use for the agent. Default: gemini-3-flash-preview
# MODEL_ID=gemini-3-flash-preview

# ── Google Sheets ────────────────────────────────────────────────────
# The long ID from the Sheet URL: https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
SPREADSHEET_ID=your-spreadsheet-id-here

# Name of the tab/sheet inside the spreadsheet (default: Sheet1)
SHEET_NAME=Sheet1

# ── Google Sheets API Key ────────────────────────────────────────────
# If using API-key auth for Sheets (same key works if Sheets API is enabled)
SHEETS_API_KEY=your-sheets-api-key-here

# ── Service Account ─────────────────────────────────────────────────
# Path to the Google Cloud service account JSON file (default: service_account.json)
# SERVICE_ACCOUNT_PATH=service_account.json

# ── Webhook Security (optional) ──────────────────────────────────────
# Shared secret between Apps Script and FastAPI (leave blank to disable)
WEBHOOK_SECRET=

# ── Server ───────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000


# ── Debugging ────────────────────────────────────────────────────────
# Set to any value (e.g. DEBUG=1) to enable DEBUG-level logging
# DEBUG=1
